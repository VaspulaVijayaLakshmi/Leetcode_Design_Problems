class NumMatrix {

    int[][] pre;

    public NumMatrix(int[][] mat) {

        int r = mat.length;
        int c = mat[0].length;

        pre = new int[r][c];

        // First cell
        pre[0][0] = mat[0][0];

        // First row
        for (int j = 1; j < c; j++) {
            pre[0][j] = pre[0][j - 1] + mat[0][j];
        }

        // First column
        for (int i = 1; i < r; i++) {
            pre[i][0] = pre[i - 1][0] + mat[i][0];
        }

        // Remaining cells
        for (int i = 1; i < r; i++) {
            for (int j = 1; j < c; j++) {


//we do -pre[i-1][j-1] because we added this 2 times..
// now we substract this one time
                pre[i][j] = pre[i - 1][j]
                          + pre[i][j - 1]
                          - pre[i - 1][j - 1]
                          + mat[i][j];
            }
        }
    }

    public int sumRegion(int r1, int c1, int r2, int c2) {

        int ans = pre[r2][c2];

        if (r1 > 0)
            ans -= pre[r1 - 1][c2];

        if (c1 > 0)
            ans -= pre[r2][c1 - 1];


//we need to add this becaise we deleted this from both orefix sums
        if (r1 > 0 && c1 > 0)
            ans += pre[r1 - 1][c1 - 1];

        return ans;
    }
}




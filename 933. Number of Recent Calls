#include <deque>
using namespace std;

class RecentCounter {
public:
    deque<int> q;

    RecentCounter() {

    }

    int ping(int t) {

        q.push_back(t);

        while (!q.empty() && t - q.front() > 3000) {
            q.pop_front();
        }

        return q.size();
    }
};



